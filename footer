/* Footer Section */
.footer{
  background: #05291b;
  color: #fff;
  padding: 50px 8%;
  font-size: 14px;
}

.footer-container{
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 30px;
}

.footer-column{
  flex: 1 1 220px;
}

.footer-column h3{
  margin-bottom: 15px;
  font-size: 18px;
  color: #00ff99;
}

.footer-column p{
  margin-bottom: 10px;
  line-height: 1.6;
}

.footer-column ul{
  list-style: none;
}

.footer-column ul li{
  margin: 6px 0;
  cursor: pointer;
  transition: .3s;
}

.footer-column ul li:hover{
  color: #00ff99;
  transform: translateX(5px);
}

.footer-column ul li a{
  color: #fff;
  text-decoration: none;
}

.footer-column ul li a:hover{
  color: #00ff99;
}

.footer-contact i{
  color: #00ff99;
  margin-right: 5px;
}

/* Copyright */
.footer-bottom{
  text-align: center;
  margin-top: 30px;
  border-top: 1px solid #0a3c2a;
  padding-top: 10px;
  font-size: 13px;
}

/* Mobile Responsive */
@media (max-width:600px){
  .footer-container{
    flex-direction: column;
  }
}






